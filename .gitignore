.hypothesis/
.vercel

# Zig
.zig-cache/
zig-out/

# Node
node_modules/
.next/

# Test outputs
tests/visual_output/
tests/visual_report.html
experiments/*/target/

# Stale pre-rebrand Rust TUI dir (renamed to cmux-tui/; old checkouts may
