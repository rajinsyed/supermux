# Xcode
.build/
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcshareddata/

# macOS
.DS_Store

# Local env
.env
.envrc
!web/.envrc
ios/Config/AppStoreConnect.local.plist

# Swift Package Manager
.swiftpm/
