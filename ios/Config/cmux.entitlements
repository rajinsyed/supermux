<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- LOCAL DEV BUILD: capabilities (Apple sign-in, APNs push, time-sensitive
	     notifications) stripped so automatic signing can provision a personal
	     team that lacks them. None are needed to test mobile mirroring (Google
	     sign-in uses a web auth session, not an entitlement). Restore with:
	         git checkout ios/Config/cmux.entitlements -->

	<!-- Example entitlements (commented out by default):

	<key>com.apple.developer.healthkit</key>
	<true/>

	<key>com.apple.developer.networking.wifi-info</key>
	<true/>

	<key>com.apple.developer.contacts.notes</key>
	<true/>

	<key>com.apple.developer.usernotifications.time-sensitive</key>
	<true/>

	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.mycompany.cmuxMobile</string>
	</array>

	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.mycompany.cmuxMobile</string>
	</array>

	-->
</dict>
</plist>
